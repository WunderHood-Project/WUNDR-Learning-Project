generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}


// ! Users       =============================================================================

model Users {
  id                String         @id @default(auto()) @map("_id") @db.ObjectId

  firstName         String
  lastName          String
  email             String          @unique
  phoneNumber       String
  role              Roles
  avatar            String?
  password          String

  address           String
  city              String
  state             String
  zipCode           String

  // m-to-n
  childIds String[]   @db.ObjectId
  children  Children[]   @relation(fields: [childIds], references: [id])

  eventIds String[] @db.ObjectId
  events Events[] @relation(fields: [eventIds], references: [id])

  createdAt         DateTime
  updatedAt         DateTime

  // One-to-m
  notifications     Notifications[]
  reviews           Reviews[]
  donations         Donations[]

  // One-to-one
  volunteer Volunteers?
}

enum Roles {
  parent
  admin
  instructor
  volunteer
}

// ! Children     =============================================================================

model Children {
  id                    String  @id @default(auto()) @map("_id") @db.ObjectId
  firstName             String
  lastName              String
  preferredName         String?
  homeschool            Boolean
  // homeschoolProgram     String?
  grade                 Int?
  birthday              DateTime
  allergiesMedical      String?
  notes                 String?
  photoConsent          Boolean
  waiver                Boolean

  waiverVersion         String?
  waiverSignedAt        DateTime?
  waiverSignedByName    String?
  
  photoConsentVer       String?
  photoConsentAt        DateTime?

  parentIds             String[]  @db.ObjectId
  parents               Users[]   @relation(fields: [parentIds], references: [id])

  eventIds              String[] @db.ObjectId
  events                Events[] @relation(fields: [eventIds], references: [id])

  emergencyContactIds   String[] @db.ObjectId
  emergencyContacts     EmergencyContact[]    @relation(name: "ChildToEmergencyContacts", fields: [emergencyContactIds], references: [id])


  createdAt             DateTime @default(now())
  updatedAt             DateTime? @updatedAt
}

//  ! Volunteer             =============================================================================

enum Days {
  Weekdays
  Weekends
}

enum AppStatus {
  New
  In_review
  Approved
  Rejected
}

model Volunteers{
  id                     String  @id @default(auto()) @map("_id") @db.ObjectId
  firstName              String
  lastName               String
  email                  String?
  phoneNumber            String?
  cities                 String[]
  daysAvail              Days[]
  timesAvail             String[]
  skills                 String[]
  bio                    String?
  photoConsent           Boolean
  backgroundCheckConsent Boolean
  status                 AppStatus @default(New)

  eventIds String[] @db.ObjectId
  events Events[] @relation(fields: [eventIds], references: [id])

  // One-to-one relationship
  user Users @relation(fields: [userId], references: [id])
  userId String @unique @db.ObjectId

  // Many-to-many relationship
  volunteerOpportunityIds String[] @db.ObjectId
  volunteerOpportunities  VolunteerOpportunities[] @relation(fields: [volunteerOpportunityIds], references: [id])

  generalAppliedAt      DateTime?

  oppAppliedAt            Json?

  createdAt             DateTime @default(now())
  updatedAt             DateTime? @updatedAt
}

//  ! Volunteer Opportunity =============================================================================

enum Venue {
  Indoors
  Outdoors
  Online
}

model VolunteerOpportunities{
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  venue           Venue[]
  duties          String[]
  skills          String[] // Optional
  time            String
  requirements    String[]
  tags            String[]
  // guide           Boolean DO WE NEED THIS?
  minAge          Int
  bgCheckRequired Boolean

  // Many-to-many relationship
  volunteerIds String[]     @db.ObjectId
  volunteers   Volunteers[] @relation(fields: [volunteerIds], references: [id])

  createdAt             DateTime @default(now())
  updatedAt             DateTime? @updatedAt
}

//  ! Emergency Contact     =============================================================================

model EmergencyContact{
  id                    String  @id @default(auto()) @map("_id") @db.ObjectId
  firstName             String
  lastName              String
  phoneNumber           String
  relationship          String
  createdAt             DateTime @default(now())
  updatedAt             DateTime? @updatedAt

  childIds              String[] @db.ObjectId
  child                 Children[] @relation(name: "ChildToEmergencyContacts", fields: [childIds], references: [id])

}

// ! Activities     =============================================================================

model Activities {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  name          String      @unique
  description   String

  events        Events[]
}

// ! Events         =============================================================================

model Events {
    id            String      @id @default(auto()) @map("_id") @db.ObjectId

    name          String      @unique
    description   String
    notes         String?
    date          DateTime
    image         String
    participants  Int @default(0)
    limit         Int @default(10)

    city          String
    state         String
    address       String
    zipCode       String
    latitude      Float?
    longitude     Float?
    startTime     String
    endTime       String
    volunteerLimit     Int @default(3)
    createdAt         DateTime @default(now())
    updatedAt         DateTime? @default(now())

    // m-to-n relationship
    volunteerIds  String[] @db.ObjectId
    volunteers Volunteers[] @relation(fields: [volunteerIds], references: [id])

    childIds  String[] @db.ObjectId
    children  Children[] @relation(fields: [childIds], references: [id])

    userIds   String[] @db.ObjectId
    users     Users[] @relation(fields: [userIds], references: [id])

    // One-to-m relationship
    activity    Activities   @relation(fields: [activityId], references: [id])
    activityId  String      @db.ObjectId

    reviews     Reviews[]

    jobs        Jobs[]
}

// ! reviews        =============================================================================

model Reviews {
    id          String      @id @default(auto()) @map("_id") @db.ObjectId
    rating      Int
    description String

    event       Events       @relation(fields: eventId, references: [id])
    eventId     String      @db.ObjectId

    parent      Users        @relation(fields: [parentId], references: [id])
    parentId    String      @db.ObjectId

    createdAt         DateTime @default(now())
    updatedAt         DateTime? @updatedAt
}

// ! Notifications   =============================================================================

model Notifications {
  id                    String  @id @default(auto()) @map("_id") @db.ObjectId
  title                 String
  description           String
  isRead                Boolean @default(false)
  time                  DateTime
  // eventDate             DateTime?  
  createdAt             DateTime  @default(now())

  user   Users   @relation(fields: [userId], references: [id])
  userId String @db.ObjectId
}

// ! jobs           =============================================================================

// ? Jobs table allows us to work with scheduling logic for notifications
enum ReminderTypes {
  email
  sms
}

enum ReminderStatus {
  pending
  sent
  undeliverable
}

enum JobTypes {
  reminder
  cancellation
}

model Jobs{
   id                String      @id @default(auto()) @map("_id") @db.ObjectId
   runAt             DateTime
   reminderType      ReminderTypes
   status            ReminderStatus
   jobType           JobTypes
   sentAt            DateTime?
   errorMessage      String?          // Log issues if notification is undeliverable

   event             Events? @relation(fields:[eventId], references: [id], onDelete: Cascade)
   eventId           String @db.ObjectId
}

// ! Donations          =============================================================================

enum DonationType {
  Sponsorship
  Donation
}

model Donations {
  id                 String      @id @default(auto()) @map("_id") @db.ObjectId
  donationType       DonationType
  amount             Int
  email              String?
  sessionId          String?       @unique

  // One-to-Many Relationship
  user   Users?   @relation(fields: [userId], references: [id])
  userId String? @db.ObjectId
}


// ! StripeEvents  =============================================================================

model StripeEvents {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId             String   @unique
  createdAt           DateTime @default(now())
}

// ! Partnership  =============================================================================

enum PartnerType {
  venue
  program
  resource
  education
}

enum PartnerStatus {
  new
  reviewing
  approved
  rejected
}

model PartnerApplications {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId

  orgName         String
  contactName     String
  email           String
  phone           String?

  partnerType     PartnerType
  website         String?
  city            String?
  state           String?

  howCanYouHelp   String?
  preferredDates  String?
  budgetOrInKind  String?
  notes           String?

  status          PartnerStatus  @default(new)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime?      @updatedAt

  @@index([email])
  @@index([partnerType])
  @@index([status])
}


// ! 1024-Waiver Credentials =============================================================================

model WaiverCredentials {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  firstName   String
	lastName    String
	address     String
	phoneNumber String   @unique
  email       String  @unique
}